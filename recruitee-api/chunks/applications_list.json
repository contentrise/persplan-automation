{
  "id": "applications_list",
  "method": "GET",
  "path": "/c/{company_id}/referral/applications",
  "summary": "List of applications with meta",
  "description": "List of applications with meta. Endpoint: GET /c/{company_id}/referral/applications. Required parameters: company_id. Optional parameters include status, q, limit, sort_by, claim_status, sort_order, page, referrer_type, and more.",
  "params": [
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "One of: [in_review, process_complete, claimed]",
      "source": "URI Parameters"
    },
    {
      "name": "q",
      "type": "string",
      "required": false,
      "description": "Search by: external user name, candidate name, offer title, reward name",
      "source": "URI Parameters"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Limit number of results, default: 1000",
      "source": "URI Parameters"
    },
    {
      "name": "sort_by",
      "type": "string",
      "required": false,
      "description": "One of: [referrer_name, candidate_name, offer_title, reward_name, referred_at], default: referred_at desc;",
      "source": "URI Parameters"
    },
    {
      "name": "claim_status",
      "type": "string",
      "required": false,
      "description": "Filter by claim status",
      "source": "URI Parameters"
    },
    {
      "name": "sort_order",
      "type": "string",
      "required": false,
      "description": "One of: [desc, asc], default: asc",
      "source": "URI Parameters"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number (1, 2, 3, …), default: 1",
      "source": "URI Parameters"
    },
    {
      "name": "referrer_type",
      "type": "string",
      "required": false,
      "description": "One of: [admin, external_user]",
      "source": "URI Parameters"
    },
    {
      "name": "with_reward",
      "type": "string",
      "required": false,
      "description": "true -> only applications with rewards; otherwise -> all",
      "source": "URI Parameters"
    },
    {
      "name": "company_id",
      "type": "integer",
      "required": true,
      "description": "Company ID",
      "source": "URI Parameters"
    }
  ],
  "example_request": "GET /c/{company_id}/referral/applications\n\nRequired params: company_id\n\nOptional params: status, q, limit, sort_by, claim_status, sort_order, page, referrer_type",
