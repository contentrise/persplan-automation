      "description": "List of tag IDs to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "priorities",
      "type": "array",
      "required": false,
      "description": "List of priorities to filter by, available: urgent, high, normal, low, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "employment_types",
      "type": "array",
      "required": false,
      "description": "List of employment types to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "experiences",
      "type": "array",
      "required": false,
      "description": "List of experiences to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "company_id",
      "type": "integer",
      "required": true,
      "description": "Company ID",
      "source": "URI Parameters"
    }
  ],
