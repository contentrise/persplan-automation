{
  "id": "offers_list",
  "method": "GET",
  "path": "/c/{company_id}/offers",
  "summary": "List offers",
  "description": "List offers. Endpoint: GET /c/{company_id}/offers. Required parameters: company_id. Optional parameters include scope, include, limit, kind, statuses, offer_ids, location_ids, hiring_manager_ids, and more.",
  "params": [
    {
      "name": "scope",
      "type": "string",
      "required": false,
      "description": "[DEPRECATED] If no scope is given list all job offers, if scope is ‘archived’ than list archived job offers, if scope is ‘active’ list published and closed job offers, if scope is ‘not_archived’ list all but archived jobs",
      "source": "URI Parameters"
    },
    {
      "name": "include",
      "type": "array",
      "required": false,
      "description": "List of includes, available: ‘description’, ‘requirements’, ‘highlight’, ‘work_models’, ‘salary’, ‘dynamic_fields’, ‘follower_ids’, ‘location_ids’, ‘requisition_ids’, ‘tags’, ‘job_scheduler’, ‘issues’, ‘counters’",
      "source": "URI Parameters"
    },
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Limit number of results, default: 1000",
      "source": "URI Parameters"
    },
    {
      "name": "kind",
      "type": "string",
      "required": false,
      "description": "[DEPRECATED] If no kind is given list all job offers, if kind is ‘job’ than list only jobs, if scope is ‘talent_pool’ list only talent pools",
      "source": "URI Parameters"
    },
    {
      "name": "statuses",
      "type": "array",
      "required": false,
      "description": "List of offer statuses to filter by, available: ‘draft’, ‘published’, ‘internal’, ‘closed’, ‘archived’, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "offer_ids",
      "type": "array",
      "required": false,
      "description": "List of offer IDs to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "location_ids",
      "type": "array",
      "required": false,
      "description": "List of location IDs to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "hiring_manager_ids",
      "type": "array",
      "required": false,
      "description": "List of hiring manager IDs to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "recruiter_ids",
      "type": "array",
      "required": false,
      "description": "List of recruiter IDs to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "lang_codes",
      "type": "array",
      "required": false,
      "description": "List of lang codes to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "categories",
      "type": "array",
      "required": false,
      "description": "List of categories to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "view_mode",
      "type": "string",
      "required": false,
      "description": "[DEPRECATED] ‘default’ (default mode, includes most of offer details); ‘brief’ (only offer’s id, title, status and kind)",
      "source": "URI Parameters"
    },
    {
      "name": "department_ids",
      "type": "array",
      "required": false,
      "description": "List of department IDs to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "page",
      "type": "integer",
      "required": false,
      "description": "Page number (1, 2, 3, …), default: 1",
      "source": "URI Parameters"
    },
    {
      "name": "educations",
      "type": "array",
      "required": false,
      "description": "List of educations to filter by, if not given all offers will be listed",
      "source": "URI Parameters"
    },
    {
      "name": "tag_ids",
      "type": "array",
