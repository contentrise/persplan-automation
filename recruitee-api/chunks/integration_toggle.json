  "params": [
    {
      "name": "enabled",
      "type": "boolean",
      "required": true,
      "description": "Integration enabled flag",
      "source": "URI Parameters"
    },
    {
      "name": "integration_type",
      "type": "string",
      "required": true,
      "description": "Integration type",
      "source": "URI Parameters"
    },
    {
      "name": "company_id",
      "type": "integer",
      "required": true,
      "description": "Company ID",
      "source": "URI Parameters"
    }
  ],
  "example_request": "Headers:\nContent-Type: application/json\n\nBody:\n{\n\"integration\": {\n\"enabled\": false\n}\n}",
  "example_response": {
    "integration": {
      "enabled": false,
      "id": 8,
      "status": "ENABLED",
