      "required": true,
      "description": "Placement ID",
      "source": "URI Parameters"
    },
    {
      "name": "proceed",
      "type": "boolean",
      "required": false,
      "description": "Placement will be placed at the top of the stage placements list if true (optional)",
      "source": "URI Parameters"
    },
    {
      "name": "hired_at",
      "type": "datetime",
      "required": false,
      "description": "When candidate was hired in the job (optional)",
      "source": "URI Parameters"
    },
    {
      "name": "work_location_id",
      "type": "integer",
      "required": false,
      "description": "Location ID (required when marking a candidate as hired)",
      "source": "URI Parameters"
    },
    {
      "name": "opening_id",
      "type": "integer",
      "required": true,
      "description": "Opening ID (required when requisitions are enabled and marking a candidate as hired)",
      "source": "URI Parameters"
    },
    {
      "name": "stage_id",
      "type": "integer",
      "required": true,
      "description": "Stage ID (change to stage sourced if ‘sourced’)",
      "source": "URI Parameters"
    },
    {
      "name": "job_starts_at",
      "type": "datetime",
      "required": false,
      "description": "When candidate starts the job (optional)",
      "source": "URI Parameters"
    },
    {
      "name": "disqualify_reason_id",
      "type": "boolean",
      "required": false,
      "description": "Disqualify other placements if the param exists. Set the disqualify reason (optional)",
      "source": "URI Parameters"
    },
    {
      "name": "run_actions",
      "type": "boolean",
      "required": false,
      "description": "Automated actions should be triggered if true (optional)",
      "source": "URI Parameters"
    },
    {
      "name": "remove_from_sharing_containers",
      "type": "boolean",
      "required": false,
      "description": "Remove from all public links (sharing containers) if it’s true (optional)",
      "source": "URI Parameters"
    },
    {
      "name": "disqualify_run_actions",
      "type": "boolean",
      "required": false,
      "description": "Run automated actions for the disqualified placements if it’s true (optional)",
      "source": "URI Parameters"
    },
    {
      "name": "company_id",
      "type": "integer",
      "required": true,
      "description": "Company ID",
      "source": "URI Parameters"
    }
  ],
  "example_request": "PATCH /c/{company_id}/placements/{id}/change_stage\n\nRequired params: id, opening_id, stage_id, company_id\n\nOptional params: proceed, hired_at, work_location_id, job_starts_at, disqualify_reason_id, run_actions, remove_from_sharing_containers, disqualify_run_actions",
