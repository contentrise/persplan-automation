{
  "id": "placement_change",
  "method": "PATCH",
  "path": "/c/{company_id}/placements/{id}/change_stage",
  "summary": "Change stage in placement",
  "description": "Change stage in placement. Endpoint: PATCH /c/{company_id}/placements/{id}/change_stage. Required parameters: id, opening_id, stage_id, company_id. Optional parameters include proceed, hired_at, work_location_id, job_starts_at, disqualify_reason_id, run_actions, remove_from_sharing_containers, disqualify_run_actions.",
  "params": [
