{
  "id": "quicks_list",
  "method": "GET",
  "path": "/c/{company_id}/search/new/quick",
  "summary": "Quick Search",
  "description": "Searches candidates, jobs, talent pools, saved searches and requisitions",
  "params": [
    {
      "name": "limit",
      "type": "integer",
      "required": false,
      "description": "Limit per each results’ type (by default: 1000)",
      "source": "URI Parameters"
    },
    {
      "name": "only",
      "type": "string",
      "required": false,
      "description": "Limit results’ type (‘all’ | ‘candidates’ | ‘jobs’ | ‘talent_pools’ | ‘requisitions’) (by default: ‘all’)",
      "source": "URI Parameters"
    },
    {
      "name": "query",
      "type": "string",
      "required": true,
      "description": "Search query",
      "source": "URI Parameters"
    },
    {
      "name": "deleted",
      "type": "boolean",
      "required": false,
      "description": "Show only deleted candidates (by default: false)",
      "source": "URI Parameters"
    },
    {
      "name": "with_emails",
      "type": "boolean",
      "required": false,
      "description": "Limit candidates to those that have at least 1 email (by default: false)",
      "source": "URI Parameters"
    },
    {
      "name": "company_id",
      "type": "integer",
      "required": true,
      "description": "Company ID",
      "source": "URI Parameters"
    }
  ],
  "example_request": "GET /c/{company_id}/search/new/quick\n\nRequired params: query, company_id\n\nOptional params: limit, only, deleted, with_emails",
